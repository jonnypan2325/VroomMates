# Example environment variables for VroomMates.
# Copy this file to `.env` and fill in your own values.
# Do NOT commit your real `.env` file.

# Google OAuth 2.0 Client ID — used by the React frontend to authenticate users.
# Must start with "REACT_APP_" so Create React App exposes it to the browser.
# Create one at https://console.cloud.google.com/apis/credentials
REACT_APP_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Google Maps JavaScript API key — used by the React frontend (interpolated
# into public/index.html at build time via Create React App's `%REACT_APP_*%`
# substitution). Must be prefixed with REACT_APP_ to be exposed to the bundle.
# Create one at https://console.cloud.google.com/apis/credentials and enable
# the "Maps JavaScript API" + "Places API" for it.
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Base URL the React frontend uses to reach the Flask backend.
REACT_APP_FLASK_API_URL=http://127.0.0.1:5000
